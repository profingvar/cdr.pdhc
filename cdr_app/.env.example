# cdr.pdhc environment — copy to .env and fill in
FLASK_APP=app
FLASK_ENV=development

# Database
POSTGRES_USER=cdr_user
POSTGRES_PASSWORD=cdr_pass
POSTGRES_DB=cdr_db
DATABASE_URL=postgresql://cdr_user:cdr_pass@localhost:9047/cdr_db

# Service keys (shared secrets for inbound auth from gateways)
GATEWAY_PDHC_SERVICE_KEY=
TWOGATE_PDHC_SERVICE_KEY=

# Cambio CDR sandbox (set CAMBIO_DELIVERY_ENABLED=true to activate)
CAMBIO_DELIVERY_ENABLED=false
CAMBIO_CLIENT_ID=
CAMBIO_CLIENT_SECRET=
CAMBIO_TOKEN_URL=
CAMBIO_BASE_URL=
CAMBIO_TENANT=sandbox-dev
CAMBIO_COMMISSION_HSA_ID=
CAMBIO_HEALTHCARE_UNIT_HSA_ID=
CAMBIO_HEALTHCARE_PROVIDER_HSA_ID=
CAMBIO_ORG_ID=

FLASK_SECRET_KEY=

# Read-side lockdown (#293). When true, only X-Source-Service:
# dashboard.pdhc is permitted on read endpoints (/api/v1/fhir/*,
# /api/v1/canonical/*, /api/v1/openehr/*, /api/v1/stats,
# /api/v1/cambio/*). Ingest endpoints stay public and accept
# gateway.pdhc + sim.pdhc as before.
# Set true on cdr2-5 + cdr_6. cdr1 ships false because gateway
# writes to cdr1 directly per SSOT.
CDR_READ_LOCKDOWN=false

# #422 — ips.pdhc consent verdicts (analysis-filter). Required in prod;
# unset => operator analysis reads fail closed (503).
IPS_BASE_URL=https://ips.pdhc.se
